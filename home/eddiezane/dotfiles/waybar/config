{
    "layer": "top", // Waybar at top layer
        "position": "bottom", // Waybar position (top|bottom|left|right)
        "spacing": 4, // Gaps between modules (4px)
        "modules-left": ["hyprland/workspaces"],
        // "modules-center": ["hyprland/window"],
        "modules-right": ["custom/notification", "custom/inhibitors", "pulseaudio", "network", "disk", "cpu", "memory", "temperature", "backlight", "power-profiles-daemon", "battery", "clock", "clock#date", "tray"],
        "fixed-center": false,
        "keyboard-state": {
            "numlock": true,
            "capslock": true,
            "format": "{name} {icon}",
            "format-icons": {
                "locked": "яАг",
                "unlocked": "яВЬ"
            }
        },
        "idle_inhibitor": {
            "format": "{icon}",
            "format-icons": {
                "activated": "яБо",
                "deactivated": "яБ░"
            }
        },
        "tray": {
            // "icon-size": 21,
            "spacing": 10
        },
        "clock": {
            "format": "{:%H:%M %Z}",
            "format-alt": "{:%I:%M%p %Z}",
            "tooltip": false
        },
        "clock#date": {
            "tooltip-format": "<tt><small>{calendar}</small></tt>",
            "format": "{:%Y-%m-%d %Z}",
            "format-alt": "{:%z}"
        },
        "power-profiles-daemon": {
            "format": "{icon}",
            "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
            "tooltip": true,
            "format-icons": {
                "default": "яДи",
                "performance": "ґ░дЗ",
                "balanced": "яЙО",
                "power-saver": "ґ░┤╗"
            }
        },
        "disk": {
            "format": "{percentage_used}% яВа"
        },
        "cpu": {
            "format": "{usage}% яЛЫ",
            "tooltip": "{load}"
        },
        "memory": {
            "format": "{}% яФ╕"
        },
        "temperature": {
            // "thermal-zone": 2,
            // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
            "critical-threshold": 80,
            // "format-critical": "{temperatureC}┬░C {icon}",
            "format": "{temperatureC}┬░C {icon}",
            "format-icons": ["яЭл", "яЛЙ", "яЭй"],
            "tooltip-format": "{temperatureF}┬░F"
        },
        "backlight": {
            // "device": "acpi_video1",
            "format": "{percent}% {icon}",
            "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
            "tooltip": false
        },
        "battery": {
            "states": {
                // "good": 95,
                "warning": 30,
                "critical": 15
            },
            "format": "{capacity}% {icon}",
            "format-charging": "{capacity}% яЧз",
            "format-plugged": "{capacity}% яЗж",
            "format-alt": "{time} {icon}",
            // "format-good": "", // An empty format will hide the module
            // "format-full": "",
            "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
        },
        "network": {
            // "interface": "wlp2*", // (Optional) To force the use of this interface
            "format-wifi": "{signalStrength}% яЗл",
            "format-ethernet": "{ipaddr}/{cidr} яЮЦ",
            "tooltip-format": "{ifname} via {gwaddr}\n{ipaddr}/{cidr}\n{essid}",
            "format-linked": "{ifname} (No IP) яЮЦ",
            "format-disconnected": "Disconnected тЪа",
            "format-alt": "{ifname}: {ipaddr}/{cidr}"
        },
        "pulseaudio": {
            // "scroll-step": 1, // %, can be a float
            "format": "{volume}% {icon} {format_source}",
            "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
            "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
            "format-muted": "яЪй {format_source}",
            "format-source": "{volume}% яД░",
            "format-source-muted": "яД▒",
            "format-icons": {
                "headphone": "яАе",
                "hands-free": "яЦР",
                "headset": "яЦР",
                "phone": "яВХ",
                "portable": "яВХ",
                "car": "яЖ╣",
                "default": ["яАж", "яАз", "яАи"]
            },
            "on-click": "pavucontrol"
        },
        "custom/inhibitors": {
            "format": "{}",
            "return-type": "json",
            "interval": 15,
            "exec": "~/.config/waybar/scripts/inhibitors.sh",
            "on-click": "~/.config/waybar/scripts/inhibitors.sh notify"
        },
        "custom/notification": {
            "tooltip": false,
            "format": "{icon}",
            "format-icons": {
                "notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
                "none": "яВв",
                "dnd-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
                "dnd-none": "яЗ╖",
                "inhibited-notification": "яВв<span foreground='red'><sup>яСД</sup></span>",
                "inhibited-none": "яВв",
                "dnd-inhibited-notification": "яЗ╖<span foreground='red'><sup>яСД</sup></span>",
                "dnd-inhibited-none": "яЗ╖"
            },
            "return-type": "json",
            "exec-if": "which swaync-client",
            "exec": "swaync-client -swb",
            "on-click": "swaync-client -t -sw",
            "on-click-right": "swaync-client -d -sw",
            "escape": true
        },
}
